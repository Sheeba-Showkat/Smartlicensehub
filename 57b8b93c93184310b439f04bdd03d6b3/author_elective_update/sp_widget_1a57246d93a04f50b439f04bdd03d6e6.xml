        <css>.smarthub-footer {
  font-family: 'Inter', sans-serif;
  background-color: transparent; /* Allows the portal background to show through */
  padding: 20px 30px;
  margin-top: auto;
}

.footer-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1px solid #e2e8f0;
  padding-top: 20px;
}

.copyright {
  font-size: 13px;
  color: #94a3b8;
  font-weight: 500;
}

.footer-links {
  display: flex;
  align-items: center;
  gap: 15px;
}

.footer-links a {
  font-size: 13px;
  color: #64748b;
  text-decoration: none;
  transition: color 0.2s;
}
.footer-links a:hover {
  color: #1e3a8a;
}
.divider {
  color: #cbd5e1;
  font-size: 10px;
}

/* Responsive constraints */
@media (max-width: 768px) {
  .footer-content {
    flex-direction: column;
    gap: 15px;
    text-align: center;
  }
}</css>
