        <client_script><![CDATA[api.controller=function($rootScope) {
  var c = this;
  c.activeBoard = 'all'; // Default board

  c.switchBoard = function(boardName) {
    c.activeBoard = boardName;
    // Broadcast an event to the VTB widget to change its data
    $rootScope.$broadcast('smarthub_vtb_changed', boardName);
  };
};]]></client_script>
